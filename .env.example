# ============================================================
# REQUIRED: Google Service Account
# ============================================================
# Full JSON content of your service account key file.
# The service account needs:
#   - Google Sheets API: Viewer access on the program sheet
#   - Google Drive API: Editor access on the Drive folder
#
# Get it from: console.cloud.google.com -> Service Accounts -> Keys
# Add it to GitHub Secrets as GOOGLE_SERVICE_ACCOUNT_JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ============================================================
# REQUIRED: Google Sheet + Drive
# ============================================================
# The ID of your training program Google Sheet
# (from the URL: /spreadsheets/d/SHEET_ID/edit)
PROGRAM_SHEET_ID=1UWTANkiCxWTl0gD1SEZA2dgn4-JukVoUZmxvoDQ0Wo8

# The ID of the Google Drive folder the Claude Project reads from
# (from the URL: /drive/folders/FOLDER_ID)
DRIVE_FOLDER_ID=1Zi6dFQA2lCRickf6XYpfedIiFPRHrTpn

# ============================================================
# OPTIONAL: Garmin Connect
# ============================================================
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# Set to 1 to test garmin_sync.py without hitting the real API
# GARMIN_MOCK=1

# How many days of Garmin history to fetch (default: 90)
# GARMIN_HISTORY_DAYS=90
